# Production environment — auto-loaded by `next build` / `next start`
# Safe to commit — contains NO secrets (secrets set in Cloudflare Pages dashboard)
# DEV TOOLS ARE ABSENT IN PRODUCTION BUILDS (NODE_ENV === 'production' at build time)

NEXT_PUBLIC_SYNTAX_API_URL=https://syntax-api.oleacomputer.com
NEXT_PUBLIC_SITE_URL=https://syntax.oleacomputer.com
NEXT_PUBLIC_OBSERVER_FREE_VERIFICATIONS=3
NEXT_PUBLIC_DEV_MODE=false
