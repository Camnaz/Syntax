# Copy this file to .env.local and fill in your values
# NEVER commit .env.local — it contains secrets

# Supabase (get from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend API (local dev: http://localhost:8080, prod: your Railway/Cloudflare URL)
NEXT_PUBLIC_SYNTAX_API_URL=http://localhost:8080

# Site URL (local: http://localhost:3000, prod: https://yourdomain.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Freemium limits
NEXT_PUBLIC_OBSERVER_FREE_VERIFICATIONS=3

# Finnhub (free key at https://finnhub.io)
NEXT_PUBLIC_FINNHUB_API_KEY=your-finnhub-key

# Stripe (get from https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_OPERATOR=price_...
STRIPE_PRICE_SOVEREIGN=price_...
STRIPE_PRICE_INSTITUTIONAL=price_...
